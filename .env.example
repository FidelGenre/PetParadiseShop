# ── Shopify (backend / catálogo) ─────────────────────────────
# Dominio de tu tienda Shopify (ej. mitienda.myshopify.com)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
# Storefront API access token
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ── Formulario de contacto (Gmail) ───────────────────────────
# Cuenta de Gmail que envía los mensajes del formulario
GMAIL_USER=
# Contraseña de aplicación de Gmail (no la contraseña normal)
GMAIL_APP_PASSWORD=
